@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment
@{
    var title = ViewData["Title"] as string ?? "DdT Manual";
}
<!DOCTYPE html>
<html lang="en" class="govuk-template govuk-template--rebranded">
<head>
  <meta charset="utf-8" />
  <title>@title</title>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#1d70b8" />
  @Html.GovUkFrontendStyleImports()
  <link rel="stylesheet" href="@Url.Content("~/_content/DfEDigital.Frontend.AspNetCore/dfe/dfe.min.css")" asp-append-version="true" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Sharp:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/gem-c-search.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/library-components.css" asp-append-version="true" />
  <link rel="icon" href="~/favicon.svg" type="image/svg+xml" asp-append-version="true" />
  <link rel="shortcut icon" href="~/favicon.ico" sizes="48x48" type="image/x-icon" asp-append-version="true" />
  @await RenderSectionAsync("Styles", required: false)
</head>
<body class="govuk-template__body use-dfe-brand">
  <script>
    document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' govuk-frontend-supported' : '');
  </script>
  <a href="#main-content" class="govuk-skip-link">Skip to main content</a>

  @await Html.PartialAsync("_DfeHeader")
  @await Html.PartialAsync("_ServiceNavigation")

  @if (IsSectionDefined("Masthead"))
  {
    @await RenderSectionAsync("Masthead", required: false)
  }

  <main id="main-content" role="main">
    <div class="govuk-main-wrapper">
      <div class="dfe-f-app-container dfe-f-app-container--wide govuk-width-container">
        @RenderBody()
      </div>
    </div>
  </main>

  @await Html.PartialAsync("_GovUkFooter")

  @Html.GovUkFrontendJsEnabledScript()
  @Html.GovUkFrontendScriptImports()
  <script src="~/js/library.js" asp-append-version="true"></script>
  @await RenderSectionAsync("Scripts", required: false)
  <script type="module">
    import { initAll as initDfeAll } from '@(Url.Content("~/_content/DfEDigital.Frontend.AspNetCore/dfe/dfe-frontend.esm.min.js"))';
    initDfeAll();
  </script>
</body>
</html>
