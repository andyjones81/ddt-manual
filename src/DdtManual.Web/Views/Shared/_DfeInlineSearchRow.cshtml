@model DdtManual.Web.Models.DfeInlineSearchRowModel
<div class="gem-c-search__item-wrapper">
    @if (!string.IsNullOrEmpty(Model.DescribedBy))
    {
        <input class="gem-c-search__item gem-c-search__input"
               id="@Model.InputId"
               name="@Model.InputName"
               type="search"
               value="@Model.Value"
               autocomplete="off"
               spellcheck="@Model.Spellcheck.ToString().ToLowerInvariant()"
               enterkeyhint="search"
               aria-describedby="@Model.DescribedBy" />
    }
    else
    {
        <input class="gem-c-search__item gem-c-search__input"
               id="@Model.InputId"
               name="@Model.InputName"
               type="search"
               value="@Model.Value"
               autocomplete="off"
               spellcheck="@Model.Spellcheck.ToString().ToLowerInvariant()"
               enterkeyhint="search" />
    }
    <div class="gem-c-search__submit-wrapper">
        <button type="submit" class="gem-c-search__submit" enterkeyhint="search" aria-label="@Model.SubmitAriaLabel">
            <svg class="gem-c-search__icon" width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
  <circle cx="12.0161" cy="11.0161" r="8.51613" stroke="currentColor" stroke-width="3"></circle>
  <line x1="17.8668" y1="17.3587" x2="26.4475" y2="25.9393" stroke="currentColor" stroke-width="3"></line>
</svg>
        </button>
    </div>
</div>
